# Copie para .env e preencha os valores reais

# === FRONTEND (Vite) ===
VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua_anon_key_aqui
VITE_JIRA_BASE_URL=https://SEU_DOMINIO.atlassian.net

# === SERVIDOR (Vercel Serverless Function) ===
# Estas variáveis NÃO têm prefixo VITE_ — são usadas somente no servidor
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_SERVICE_KEY=sua_service_role_key_aqui
JIRA_BASE_URL=https://SEU_DOMINIO.atlassian.net
JIRA_EMAIL=seu@email.com
JIRA_API_TOKEN=seu_api_token_jira
JIRA_PROJECT_KEY=SIGLA
JIRA_JQL=project = SIGLA AND issuetype = Story ORDER BY created DESC
ALLOWED_EMAIL_DOMAIN=seudominio.com.br
OPENROUTER_API_KEY=sua_chave_aqui
OPENROUTER_MODEL=anthropic/claude-opus-4-5
OPENROUTER_SITE_URL=https://seu-dominio.com
OPENROUTER_APP_NAME=IA360 Dashboard
